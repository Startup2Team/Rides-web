# taravelis-admin — production env (copy to .env.production on the server)
#
# NEXT_PUBLIC_API_URL is baked into the browser bundle at BUILD time. It must be
# the PUBLIC API URL the user's browser can reach.
NEXT_PUBLIC_API_URL=https://api.rides.rw/api/v1

# BACKEND_ORIGIN is used server-side (Next route handlers proxying to the Go API).
# Inside the Docker network the API service is reachable as http://api:8080.
BACKEND_ORIGIN=http://api:8080
